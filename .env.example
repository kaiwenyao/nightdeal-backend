# 应用配置
PORT=3000

# 数据库（本地开发用 localhost，Docker 部署用容器名 postgres）
DATABASE_URL=postgresql://nightdeal:nightdeal@localhost:5432/nightdeal

# Redis（本地开发用 localhost，Docker 部署用容器名 redis）
REDIS_URL=redis://localhost:6379

# 微信小程序
WX_APPID=***REMOVED_APPID***
WX_SECRET=your_wx_secret_here
WX_LOGIN_TIMEOUT_MS=8000

# JWT（至少 32 字符）
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# 会话加密密钥（至少 32 字符，用于加密微信 session_key，独立于 JWT_SECRET）
SESSION_ENCRYPTION_KEY=your_session_encryption_key_here_at_least_32_chars

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=https://your-bucket.oss-your-region.aliyuncs.com
OSS_BUCKET=your-bucket
OSS_REGION=oss-your-region
OSS_AVATAR_KEY_PREFIX=avatars/
AVATAR_URL_PREFIX=https://your-bucket.oss-your-region.aliyuncs.com/avatars/

# CORS（可选）
# 浏览器或 H5 调试需要跨域时填写明确来源；小程序 request 不依赖浏览器 CORS。
CORS_ORIGIN=
# 设置为 false 时 HTTP CORS 不携带 credentials；未设置 CORS_ORIGIN 时 HTTP origin 使用 *。
CORS_CREDENTIALS=true
